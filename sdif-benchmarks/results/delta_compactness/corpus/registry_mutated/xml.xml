<?xml version="1.0" encoding="UTF-8"?>
<document>
  <kind>Registry</kind>
  <id>example.registry</id>
  <schema>example.semantic_registry.v1</schema>
  <authority>Canonical-v2</authority>
  <lifecycle>Active</lifecycle>
  <entries>
    <item>
      <id>example.schema-v2</id>
      <kind>Schema</kind>
      <lifecycle>Active</lifecycle>
      <authority>Canonical-v2</authority>
      <path>schemas/example.schema.sdif</path>
      <evidence>reports/schema.md-v2</evidence>
    </item>
    <item>
      <id>example.registry</id>
      <kind>Registry</kind>
      <lifecycle>Active</lifecycle>
      <authority>Canonical</authority>
      <path>registry/example.registry.sdif</path>
      <evidence>reports/registry.md</evidence>
    </item>
    <item>
      <id>validator.core</id>
      <kind>Tool</kind>
      <lifecycle>Active</lifecycle>
      <authority>Canonical</authority>
      <path>tools/validator.md</path>
      <evidence>reports/validator.md</evidence>
    </item>
  </entries>
  <rel>
    <item>
      <subject>example.registry</subject>
      <predicate>governed_by</predicate>
      <object>example.schema</object>
    </item>
    <item>
      <subject>example.registry</subject>
      <predicate>validated_by</predicate>
      <object>validator.core</object>
    </item>
    <item>
      <subject>validator.core</subject>
      <predicate>emits</predicate>
      <object>reports/validator.md</object>
    </item>
  </rel>
  <rules>
    <item>(deny missing(entries.evidence))</item>
    <item>(deny dangling(rel))</item>
    <item>(deny invalid(entries.lifecycle))</item>
  </rules>
</document>
